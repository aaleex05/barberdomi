---
import Icon from './Icon.astro';
const year = new Date().getFullYear();
---

<footer class="bg-gradient-to-r from-neutral-950 to-zinc-900 text-red-300 py-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row justify-between items-center animate-fade-in">
      <div class="flex items-center space-x-2 mb-4 md:mb-0">
        <Icon name="scissors" class="h-5 w-5" />
        <span class="font-bold">La Barbería Imperial</span>
      </div>
      <p class="text-sm">{ year } Alex Aperador. </p> <a href="https://alexaperador.dev" class="text-red-300 hover:text-red-400">alexaperador.dev</a>
    </div>
  </div>
</footer>
