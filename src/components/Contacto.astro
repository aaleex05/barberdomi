---
import Button from "./Button.astro";
import Icon from "./Icon.astro";
---

<section
  id="contacto"
  class="py-25 bg-gradient-to-r from-neutral-900 to-zinc-800 text-white"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16 animate-fade-in">
      <h2 class="text-4xl font-bold mb-4">Visítanos</h2>
      <p class="text-red-100 text-xl max-w-2xl mx-auto">
        Estamos ubicados en el corazón de Barcelona. Ven a conocernos y descubre
        por qué somos la barbería de referencia en la ciudad.
      </p>
    </div>

    <div class="grid lg:grid-cols-2 gap-12">
      <div class="animate-slide-in-left">
        <div class="space-y-8">
          <div
            class="flex items-start space-x-4 hover:scale-105 transform transition-all"
          >
            <Icon name="map-pin" class="h-6 w-6 text-red-300 mt-1" />
            <div>
              <h3 class="font-semibold mb-1 text-xl">Dirección</h3>
              <p class="text-red-200 text-lg">
                C/ de la Barbería, 123<br />
                Barcelona<br />
              </p>
            </div>
          </div>

          <div
            class="flex items-start space-x-4 hover:scale-105 transform transition-all"
          >
            <Icon name="clock" class="h-6 w-6 text-red-300 mt-1" />
            <div>
              <h3 class="font-semibold mb-1 text-xl">Horarios</h3>
              <p class="text-red-200 text-lg">
                Lun - Jue: 10:00 - 14:00 / 15:30 - 20:30<br />
                Vie: 9:30 - 14:00 / 15:00 - 20:30<br />
                Dom: Cerrado
              </p>
            </div>
          </div>

          <div
            class="flex items-start space-x-4 hover:scale-105 transform transition-all"
          >
            <Icon name="phone" class="h-6 w-6 text-red-300 mt-1" />
            <div>
              <h3 class="font-semibold mb-1 text-xl">Teléfono</h3>
              <p class="text-red-200 text-lg">+34 000 000 000</p>
            </div>
          </div>
        </div>

        <div class="flex space-x-4 mt-8">
          <Button
            href="#"
            variant="outline"
            size="icon"
            class="border-zinc-700 hover:bg-zinc-800 hover:border-zinc-600 hover:scale-110 transform transition-all"
          >
            <Icon name="instagram" class="h-5 w-5" />
          </Button>
          <Button
            variant="outline"
            size="icon"
            class="border-zinc-700 hover:bg-zinc-800 hover:border-zinc-600 hover:scale-110 transform transition-all"
          >
            <Icon name="phone" class="h-5 w-5" />
          </Button>
          <Button
            variant="outline"
            size="icon"
            class="border-zinc-700 hover:bg-zinc-800 hover:border-zinc-600 hover:scale-110 transform transition-all"
          >
            <Icon name="mail" class="h-5 w-5" />
          </Button>
        </div>
      </div>

      <div class="animate-slide-in-right">
        <div
          class="bg-gradient-to-r from-neutral-900 to-zinc-900 p-2 rounded-2xl shadow-2xl hover:scale-105 transform transition-all duration-500"
        >
          <div class="rounded-xl overflow-hidden h-96">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d95780.66765474487!2d2.0576174004169916!3d41.392638536056!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x12a49816718e30e5%3A0x44b0fb3d4f47660a!2sBarcelona%2C%20Espa%C3%B1a!5e0!3m2!1ses!2sus!4v1773084121491!5m2!1ses!2sus"
              width="600"
              height="450"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"></iframe>
          </div>
          <div class="p-4 text-center">
            <h3 class="font-semibold text-lg mb-2">Encuéntranos aquí</h3>
            <p class="text-red-200 text-sm">
              Haz clic en el mapa para obtener direcciones
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
